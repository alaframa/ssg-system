// prisma/schema.prisma
// SSG Gas Distribution System
// Branches: Surabaya & Yogyakarta | Supplier: PT Arsygas Nix Indonesia
// Updated: Added CustomerPo (customer orders TO SSG)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum BranchCode {
  SBY  // Surabaya
  YOG  // Yogyakarta
}

enum CylinderSize {
  KG3
  KG5_5
  KG12
  KG50
}

enum PoStatus {
  DRAFT
  SUBMITTED
  CONFIRMED
  PARTIALLY_RECEIVED
  COMPLETED
  CANCELLED
}

enum DoStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  PARTIAL
  CANCELLED
}

enum CustomerType {
  RETAIL
  AGEN
  INDUSTRI
}

enum WriteoffReason {
  RUSAK_BERAT
  HILANG
  KADALUARSA_UJI
  BOCOR_PARAH
}

enum ReconciliationStatus {
  DRAFT
  LOCKED
  APPROVED
}

enum GasbackTxType {
  CREDIT      // cylinder deposit received
  DEBIT       // cylinder returned / claimed
  ADJUSTMENT
}

enum UserRole {
  SUPER_ADMIN
  BRANCH_MANAGER
  WAREHOUSE_STAFF
  SALES_STAFF
  FINANCE
  READONLY
}

enum OrderChannel {
  WHATSAPP
  PHONE
  WALK_IN
  SALES_VISIT
}

// ─────────────────────────────────────────────
// 1. BRANCH
// ─────────────────────────────────────────────

model Branch {
  id          String     @id @default(cuid())
  code        BranchCode @unique
  name        String     @db.VarChar(120)
  address     String?    @db.Text
  phone       String?    @db.VarChar(30)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  users                  User[]
  customers              Customer[]
  supplierPos            SupplierPo[]
  customerPos            CustomerPo[]
  deliveryOrders         DeliveryOrder[]
  inboundReceivings      InboundReceiving[]
  emptyReturns           EmptyReturn[]
  cylinderWriteoffs      CylinderWriteoff[]
  warehouseStocks        WarehouseStock[]
  monthlyRecons          MonthlyRecon[]
  supplierHmtQuotas      SupplierHmtQuota[]

  @@map("branch")
}

// ─────────────────────────────────────────────
// 2. SUPPLIER
// ─────────────────────────────────────────────

model Supplier {
  id          String   @id @default(cuid())
  code        String   @unique @db.VarChar(20)
  name        String   @db.VarChar(200)
  npwp        String?  @db.VarChar(30)
  address     String?  @db.Text
  phone       String?  @db.VarChar(30)
  email       String?  @db.VarChar(120)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  supplierHmtQuotas SupplierHmtQuota[]
  supplierPos       SupplierPo[]

  @@map("supplier")
}

// ─────────────────────────────────────────────
// 3. SUPPLIER_HMT_QUOTA
// ─────────────────────────────────────────────

model SupplierHmtQuota {
  id             String       @id @default(cuid())
  supplierId     String
  branchId       String
  cylinderSize   CylinderSize
  periodMonth    Int
  periodYear     Int
  quotaQty       Int
  usedQty        Int          @default(0)
  pricePerUnit   Decimal      @db.Decimal(14, 2)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  supplier  Supplier @relation(fields: [supplierId], references: [id])
  branch    Branch   @relation(fields: [branchId], references: [id])

  @@unique([supplierId, branchId, cylinderSize, periodMonth, periodYear])
  @@index([branchId, periodYear, periodMonth])
  @@map("supplier_hmt_quota")
}

// ─────────────────────────────────────────────
// 4. CUSTOMER
// ─────────────────────────────────────────────

model Customer {
  id             String       @id @default(cuid())
  branchId       String
  code           String       @unique @db.VarChar(30)
  name           String       @db.VarChar(200)
  customerType   CustomerType @default(RETAIL)
  address        String?      @db.Text
  phone          String?      @db.VarChar(30)
  email          String?      @db.VarChar(120)
  npwp           String?      @db.VarChar(30)
  creditLimit    Decimal      @default(0) @db.Decimal(16, 2)
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  branch                 Branch                    @relation(fields: [branchId], references: [id])
  customerPos            CustomerPo[]
  deliveryOrders         DeliveryOrder[]
  cylinderHoldings       CustomerCylinderHolding[]
  gasbackLedgers         GasbackLedger[]
  gasbackClaims          GasbackClaim[]

  @@index([branchId])
  @@index([customerType])
  @@map("customer")
}

// ─────────────────────────────────────────────
// 5. SUPPLIER_PO  (SSG orders FROM supplier)
// ─────────────────────────────────────────────

model SupplierPo {
  id             String       @id @default(cuid())
  branchId       String
  supplierId     String
  poNumber       String       @unique @db.VarChar(40)
  poDate         DateTime     @db.Date
  cylinderSize   CylinderSize
  orderedQty     Int
  confirmedQty   Int          @default(0)
  receivedQty    Int          @default(0)
  pricePerUnit   Decimal      @db.Decimal(14, 2)
  status         PoStatus     @default(DRAFT)
  notes          String?      @db.Text
  createdById    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  branch            Branch             @relation(fields: [branchId], references: [id])
  supplier          Supplier           @relation(fields: [supplierId], references: [id])
  createdBy         User               @relation("SupplierPoCreatedBy", fields: [createdById], references: [id])
  inboundReceivings InboundReceiving[]

  @@index([branchId, status])
  @@index([poDate])
  @@map("supplier_po")
}

// ─────────────────────────────────────────────
// 6. CUSTOMER_PO  (Customer orders TO SSG)
//    Via WhatsApp, phone, walk-in, sales visit
// ─────────────────────────────────────────────

model CustomerPo {
  id             String       @id @default(cuid())
  branchId       String
  customerId     String
  poNumber       String       @unique @db.VarChar(40)
  poDate         DateTime     @db.Date
  cylinderSize   CylinderSize
  orderedQty     Int
  confirmedQty   Int          @default(0)
  fulfilledQty   Int          @default(0)   // total delivered across all DOs
  pricePerUnit   Decimal      @db.Decimal(14, 2)
  status         PoStatus     @default(SUBMITTED)
  orderChannel   OrderChannel @default(WHATSAPP)
  notes          String?      @db.Text
  createdById    String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  branch         Branch          @relation(fields: [branchId], references: [id])
  customer       Customer        @relation(fields: [customerId], references: [id])
  createdBy      User            @relation("CustomerPoCreatedBy", fields: [createdById], references: [id])
  deliveryOrders DeliveryOrder[]

  @@index([branchId, status])
  @@index([customerId])
  @@index([poDate])
  @@map("customer_po")
}

// ─────────────────────────────────────────────
// 7. DELIVERY_ORDER  (outbound to customer)
// ─────────────────────────────────────────────

model DeliveryOrder {
  id             String     @id @default(cuid())
  branchId       String
  customerId     String
  customerPoId   String?    // link to CustomerPo (required going forward)
  doNumber       String     @unique @db.VarChar(40)
  doDate         DateTime   @db.Date
  cylinderSize   CylinderSize
  orderedQty     Int
  deliveredQty   Int        @default(0)
  pricePerUnit   Decimal    @db.Decimal(14, 2)
  status         DoStatus   @default(PENDING)
  vehicleNo      String?    @db.VarChar(20)
  driverName     String?    @db.VarChar(100)
  notes          String?    @db.Text
  deliveredAt    DateTime?
  createdById    String
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  branch      Branch      @relation(fields: [branchId], references: [id])
  customer    Customer    @relation(fields: [customerId], references: [id])
  customerPo  CustomerPo? @relation(fields: [customerPoId], references: [id])
  createdBy   User        @relation("DeliveryOrderCreatedBy", fields: [createdById], references: [id])

  @@index([branchId, status])
  @@index([customerId])
  @@index([customerPoId])
  @@index([doDate])
  @@map("delivery_order")
}

// ─────────────────────────────────────────────
// 8. INBOUND_RECEIVING  (goods receipt from supplier)
// ─────────────────────────────────────────────

model InboundReceiving {
  id             String       @id @default(cuid())
  branchId       String
  supplierPoId   String
  grNumber       String       @unique @db.VarChar(40)
  receivedDate   DateTime     @db.Date
  cylinderSize   CylinderSize
  receivedQty    Int
  goodQty        Int
  rejectQty      Int          @default(0)
  notes          String?      @db.Text
  receivedById   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  branch      Branch     @relation(fields: [branchId], references: [id])
  supplierPo  SupplierPo @relation(fields: [supplierPoId], references: [id])
  receivedBy  User       @relation("InboundReceivedBy", fields: [receivedById], references: [id])

  @@index([branchId, receivedDate])
  @@index([supplierPoId])
  @@map("inbound_receiving")
}

// ─────────────────────────────────────────────
// 9. EMPTY_RETURN
// ─────────────────────────────────────────────

model EmptyReturn {
  id             String       @id @default(cuid())
  branchId       String
  returnNumber   String       @unique @db.VarChar(40)
  returnDate     DateTime     @db.Date
  cylinderSize   CylinderSize
  returnedQty    Int
  sourceType     String       @db.VarChar(20)   // CUSTOMER | DRIVER | DEPOT
  sourceRef      String?      @db.VarChar(100)
  notes          String?      @db.Text
  recordedById   String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  branch      Branch @relation(fields: [branchId], references: [id])
  recordedBy  User   @relation("EmptyReturnRecordedBy", fields: [recordedById], references: [id])

  @@index([branchId, returnDate])
  @@map("empty_return")
}

// ─────────────────────────────────────────────
// 10. CYLINDER_WRITEOFF
// ─────────────────────────────────────────────

model CylinderWriteoff {
  id             String         @id @default(cuid())
  branchId       String
  writeoffNumber String         @unique @db.VarChar(40)
  writeoffDate   DateTime       @db.Date
  cylinderSize   CylinderSize
  qty            Int
  reason         WriteoffReason
  serialNumbers  String?        @db.Text
  approvedById   String?
  notes          String?        @db.Text
  createdById    String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  branch      Branch @relation(fields: [branchId], references: [id])
  createdBy   User   @relation("WriteoffCreatedBy",   fields: [createdById],   references: [id])
  approvedBy  User?  @relation("WriteoffApprovedBy",  fields: [approvedById],  references: [id])

  @@index([branchId, writeoffDate])
  @@map("cylinder_writeoff")
}

// ─────────────────────────────────────────────
// 11. WAREHOUSE_STOCK
// ─────────────────────────────────────────────

model WarehouseStock {
  id             String       @id @default(cuid())
  branchId       String
  cylinderSize   CylinderSize
  stockDate      DateTime     @db.Date
  fullQty        Int          @default(0)
  emptyQty       Int          @default(0)
  onTransitQty   Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  branch Branch @relation(fields: [branchId], references: [id])

  @@unique([branchId, cylinderSize, stockDate])
  @@index([branchId, stockDate])
  @@map("warehouse_stock")
}

// ─────────────────────────────────────────────
// 12. CUSTOMER_CYLINDER_HOLDING
// ─────────────────────────────────────────────

model CustomerCylinderHolding {
  id             String       @id @default(cuid())
  customerId     String
  cylinderSize   CylinderSize
  heldQty        Int          @default(0)
  depositPerUnit Decimal      @default(0) @db.Decimal(14, 2)
  lastUpdated    DateTime     @default(now())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  customer Customer @relation(fields: [customerId], references: [id])

  @@unique([customerId, cylinderSize])
  @@index([customerId])
  @@map("customer_cylinder_holding")
}

// ─────────────────────────────────────────────
// 13. GASBACK_LEDGER
// ─────────────────────────────────────────────

model GasbackLedger {
  id             String        @id @default(cuid())
  customerId     String
  txType         GasbackTxType
  cylinderSize   CylinderSize
  qty            Int
  amountPerUnit  Decimal       @db.Decimal(14, 2)
  totalAmount    Decimal       @db.Decimal(16, 2)
  runningBalance Decimal       @db.Decimal(16, 2)
  refType        String?       @db.VarChar(40)
  refId          String?
  txDate         DateTime      @db.Date
  notes          String?       @db.Text
  createdById    String
  createdAt      DateTime      @default(now())

  customer   Customer @relation(fields: [customerId], references: [id])
  createdBy  User     @relation("GasbackLedgerCreatedBy", fields: [createdById], references: [id])

  @@index([customerId, txDate])
  @@index([refType, refId])
  @@map("gasback_ledger")
}

// ─────────────────────────────────────────────
// 14. GASBACK_CLAIM
// ─────────────────────────────────────────────

model GasbackClaim {
  id            String       @id @default(cuid())
  customerId    String
  claimNumber   String       @unique @db.VarChar(40)
  claimDate     DateTime     @db.Date
  cylinderSize  CylinderSize
  claimedQty    Int
  amountPerUnit Decimal      @db.Decimal(14, 2)
  totalClaimed  Decimal      @db.Decimal(16, 2)
  isPaid        Boolean      @default(false)
  paidAt        DateTime?
  paymentRef    String?      @db.VarChar(100)
  notes         String?      @db.Text
  createdById   String
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  customer   Customer @relation(fields: [customerId], references: [id])
  createdBy  User     @relation("GasbackClaimCreatedBy", fields: [createdById], references: [id])

  @@index([customerId])
  @@index([claimDate])
  @@map("gasback_claim")
}

// ─────────────────────────────────────────────
// 15. MONTHLY_RECON
// ─────────────────────────────────────────────

model MonthlyRecon {
  id               String               @id @default(cuid())
  branchId         String
  periodMonth      Int
  periodYear       Int
  cylinderSize     CylinderSize
  openingFull      Int                  @default(0)
  openingEmpty     Int                  @default(0)
  inboundFull      Int                  @default(0)
  outboundFull     Int                  @default(0)
  returnedEmpty    Int                  @default(0)
  writeoffQty      Int                  @default(0)
  closingFull      Int                  @default(0)
  closingEmpty     Int                  @default(0)
  systemFull       Int                  @default(0)
  systemEmpty      Int                  @default(0)
  varianceFull     Int                  @default(0)
  varianceEmpty    Int                  @default(0)
  status           ReconciliationStatus @default(DRAFT)
  approvedById     String?
  approvedAt       DateTime?
  notes            String?              @db.Text
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  branch      Branch @relation(fields: [branchId], references: [id])
  approvedBy  User?  @relation("MonthlyReconApprovedBy", fields: [approvedById], references: [id])

  @@unique([branchId, cylinderSize, periodMonth, periodYear])
  @@index([branchId, periodYear, periodMonth])
  @@map("monthly_recon")
}

// ─────────────────────────────────────────────
// 16. USER
// ─────────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  branchId       String?
  email          String    @unique @db.VarChar(200)
  name           String    @db.VarChar(120)
  hashedPassword String?   @db.Text
  role           UserRole  @default(READONLY)
  isActive       Boolean   @default(true)
  emailVerified  DateTime?
  image          String?   @db.Text
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  accounts  Account[]
  sessions  Session[]

  branch                Branch?            @relation(fields: [branchId], references: [id])
  createdSupplierPos    SupplierPo[]       @relation("SupplierPoCreatedBy")
  createdCustomerPos    CustomerPo[]       @relation("CustomerPoCreatedBy")
  createdDos            DeliveryOrder[]    @relation("DeliveryOrderCreatedBy")
  inboundReceivings     InboundReceiving[] @relation("InboundReceivedBy")
  emptyReturns          EmptyReturn[]      @relation("EmptyReturnRecordedBy")
  writeoffsCreated      CylinderWriteoff[] @relation("WriteoffCreatedBy")
  writeoffsApproved     CylinderWriteoff[] @relation("WriteoffApprovedBy")
  gasbackLedgers        GasbackLedger[]    @relation("GasbackLedgerCreatedBy")
  gasbackClaims         GasbackClaim[]     @relation("GasbackClaimCreatedBy")
  monthlyReconsApproved MonthlyRecon[]     @relation("MonthlyReconApprovedBy")

  @@index([branchId])
  @@map("user")
}

// ─────────────────────────────────────────────
// NextAuth required tables
// ─────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("account")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("session")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_token")
}
